{
    "widgets": [
        {
            "type": "metric",
            "properties": {
                "title": "Request Count by Service",
                "region": "ap-southeast-2",
                "metrics": [
                    ["Notiver", "APIRequests", "service", "data-collection"],
                    ["Notiver", "APIRequests", "service", "data-retrieval"],
                    ["Notiver", "APIRequests", "service", "data-processing"]
                ],
                "period": 300,
                "stat": "Sum",
                "view": "timeSeries"
            }
        },
        {
            "type": "metric",
            "properties": {
                "title": "Error Count",
                "region": "ap-southeast-2",
                "metrics": [
                    ["Notiver", "Errors", "service", "data-collection"],
                    ["Notiver", "Errors", "service", "data-retrieval"],
                    ["Notiver", "Errors", "service", "data-processing"]
                ],
                "period": 300,
                "stat": "Sum",
                "view": "timeSeries"
            }
        },
        {
            "type": "metric",
            "properties": {
                "title": "Response Time",
                "region": "ap-southeast-2",
                "metrics": [
                    ["Notiver", "Latency", "service", "data-collection"],
                    ["Notiver", "Latency", "service", "data-retrieval"],
                    ["Notiver", "Latency", "service", "data-processing"]
                ],
                "period": 300,
                "stat": "Average",
                "view": "timeSeries"
            }
        },
        {
            "type": "metric",
            "properties": {
                "title": "Lambda Duration",
                "region": "ap-southeast-2",
                "metrics": [
                    ["AWS/Lambda", "Duration", "FunctionName", "data-collection-function"],
                    ["AWS/Lambda", "Duration", "FunctionName", "data-retrieval-function"],
                    ["AWS/Lambda", "Duration", "FunctionName", "data-nlp-analytics"]
                ],
                "period": 300,
                "stat": "Average",
                "view": "timeSeries"
            }
        },
        {
            "type": "metric",
            "properties": {
                "title": "Slow Responses",
                "region": "ap-southeast-2",
                "metrics": [
                    ["Notiver", "SlowResponses", "service", "data-collection"],
                    ["Notiver", "SlowResponses", "service", "data-retrieval"],
                    ["Notiver", "SlowResponses", "service", "data-processing"]
                ],
                "period": 300,
                "stat": "Sum",
                "view": "timeSeries"
            }
        },
        {
            "type": "metric",
            "properties": {
                "title": "Spam Events",
                "region": "ap-southeast-2",
                "metrics": [
                    ["Notiver", "SpamEvents", "service", "data-collection"],
                    ["Notiver", "SpamEvents", "service", "data-processing"]
                ],
                "period": 300,
                "stat": "Sum",
                "view": "timeSeries"
            }
        },
        {
            "type": "metric",
            "properties": {
                "title": "Storage Events",
                "region": "ap-southeast-2",
                "metrics": [
                    ["Notiver", "SpamEvents", "service", "data-collection"]
                ],
                "period": 300,
                "stat": "Sum",
                "view": "timeSeries"
            }
        },
        {
            "type": "log",
            "properties": {
                "title": "Recent Errors",
                "queryString": "fields @timestamp, @message | filter @message like /ERROR/ or level = \"ERROR\" | sort @timestamp desc | limit 20",
                "logGroupNames": [
                    "/aws/lambda/data-collection-function",
                    "/aws/lambda/data-retrieval-function",
                    "/aws/lambda/data-nlp-analytics"
                ],
                "view": "table"
            }
        },
        {
            "type": "log",
            "properties": {
                "title": "Request Count by Endpoint",
                "queryString": "fields endpoint | stats count(*) as requests by endpoint | sort requests desc",
                "logGroupNames": [
                    "/aws/lambda/data-collection-function",
                    "/aws/lambda/data-retrieval-function",
                    "/aws/lambda/data-nlp-analytics"
                ],
                "view": "table"
            }
        },
        {
            "type": "log",
            "properties": {
                "title": "Average Response Time by Endpoint",
                "queryString": "fields endpoint, duration_ms | stats avg(duration_ms) as avg_ms by endpoint | sort avg_ms desc",
                "logGroupNames": [
                    "/aws/lambda/data-collection-function",
                    "/aws/lambda/data-retrieval-function",
                    "/aws/lambda/data-nlp-analytics"
                ],
                "view": "table"
            }
        },
        {
            "type": "log",
            "properties": {
                "title": "Top Callers by IP",
                "queryString": "fields caller_ip | stats count(*) as requests by caller_ip | sort requests desc | limit 10",
                "logGroupNames": [
                    "/aws/lambda/data-collection-function",
                    "/aws/lambda/data-retrieval-function",
                    "/aws/lambda/data-nlp-analytics"
                ],
                "view": "table"
            }
        },
        {
            "type": "log",
            "properties": {
                "title": "Spam Events",
                "queryString": "fields @timestamp, caller_ip, endpoint, reason | filter event_type = \"spam\" | sort @timestamp desc | limit 20",
                "logGroupNames": [
                    "/aws/lambda/data-collection-function",
                    "/aws/lambda/data-nlp-analytics"
                ],
                "view": "table"
            }
        }
    ]
}